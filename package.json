{
  "name": "workbom",
  "private": true,
  "version": "0.1.90",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "clean": "rm -rf dist src-tauri/target .ai-sessions && find . -name '.DS_Store' -delete 2>/dev/null; ls -t releases/*.dmg 2>/dev/null | tail -n +2 | xargs rm -f 2>/dev/null; echo 'Cleaned build cache, dist, old DMGs'",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:app": "CARGO_TARGET_DIR=\"$PWD/src-tauri/target\" tauri build && mkdir -p releases && VER=$(node -p \"require('./package.json').version\") && DMG=\"WorkBOM_${VER}_aarch64.dmg\" && (cp \"src-tauri/target/release/bundle/dmg/$DMG\" \"releases/$DMG\" || hdiutil create -volname \"WorkBOM\" -srcfolder src-tauri/target/release/bundle/macos/WorkBOM.app -ov -format UDZO \"releases/$DMG\")"
  },
  "dependencies": {
    "@radix-ui/react-avatar": "^1.2.2",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-scroll-area": "^1.2.14",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-opener": "^2",
    "@tremor/react": "^3.18.7",
    "@xyflow/react": "^12.11.2",
    "autoprefixer": "^10.5.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3-drag": "^3.0.0",
    "d3-force": "^3.0.0",
    "d3-quadtree": "^3.0.1",
    "d3-selection": "^3.0.0",
    "d3-transition": "^3.0.1",
    "d3-zoom": "^3.0.0",
    "html-to-image": "^1.11.13",
    "lucide-react": "^1.24.0",
    "postcss": "^8.5.16",
    "postprocessing": "^6.39.2",
    "react": "^19.1.0",
    "react-arborist": "^3.13.2",
    "react-dom": "^19.1.0",
    "react-force-graph-3d": "^1.29.1",
    "react-resizable-panels": "^2.1.9",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.185.1",
    "three-spritetext": "^1.10.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/d3-drag": "^3.0.7",
    "@types/d3-force": "^3.0.10",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-transition": "^3.0.9",
    "@types/d3-zoom": "^3.0.8",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^3.2.7"
  }
}
